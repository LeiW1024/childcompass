# ─────────────────────────────────────────────
# ChildCompass — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase ────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Prisma / PostgreSQL ──────────────────────
# Supabase → Settings → Database → Connection string (Transaction pooler)
DATABASE_URL="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase → Settings → Database → Direct connection string
DIRECT_URL="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Admin panel password (choose any strong password)
ADMIN_SECRET_KEY=your-secret-admin-password

# Anthropic API key (for the scraper tool)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mapbox public token (get from mapbox.com → your account → tokens)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
